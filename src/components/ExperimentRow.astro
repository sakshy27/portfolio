---
interface Props {
  href: string;
  title: string;
  desc: string;
}

const { href, title, desc } = Astro.props;
---

<a href={href} class="exp" {...(href.startsWith('http') ? { target: '_blank', rel: 'noopener' } : {})}>
  <div class="e-body">
    <div class="e-title">{title}</div>
    <div class="e-desc">{desc}</div>
  </div>
  <svg class="e-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 8h9M8.5 4l4 4-4 4"/></svg>
</a>

<style>
  .exp {
    display: grid;
    grid-template-columns: 1fr 24px;
    gap: var(--space-18);
    padding: var(--space-16) 0;
    border-bottom: 1px solid var(--line);
    align-items: center;
    transition: padding var(--ease-default);
  }
  .exp:hover { padding-left: var(--space-6); }
  .exp:hover .e-title { color: var(--accent); }
  .exp:hover .e-arrow { color: var(--accent); transform: translateX(3px); }
  .e-body { min-width: 0; width: 100%; }
  .e-title {
    font-size: var(--text-exp-title);
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 2px;
    transition: color var(--ease-default);
  }
  .e-desc {
    font-size: var(--text-exp-desc);
    color: var(--ink-2);
    line-height: var(--leading-exp);
  }
  .e-arrow {
    color: var(--muted-2);
    transition: color var(--ease-default), transform var(--ease-default);
    flex-shrink: 0;
  }
</style>
