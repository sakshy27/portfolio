<style>
  footer {
    padding: var(--space-56) 0 var(--space-56);
    margin-top: 0;
    border-top: none;
  }
  h3 {
    font-size: var(--text-footer-heading);
    font-weight: var(--weight-medium);
    letter-spacing: 0.02em;
    line-height: var(--leading-heading);
    margin-bottom: var(--space-32);
    max-width: 620px;
  }
  .accent { color: var(--accent); }
  .email-hero {
    display: inline-block;
    font-size: var(--text-email);
    font-weight: var(--weight-regular);
    letter-spacing: 0.02em;
    line-height: var(--leading-tight);
    color: var(--ink-2);
    margin: var(--space-8) 0 var(--space-48);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: var(--space-6);
    transition: color var(--ease-smooth), border-color var(--ease-smooth);
  }
  .email-hero .arrow {
    font-family: var(--font-mono);
    font-size: 0.6em;
    margin-left: 12px;
    vertical-align: 0.2em;
    color: var(--muted-2);
    display: inline-block;
    transition: transform var(--ease-email), color var(--ease-smooth);
  }
  .email-hero:hover { color: var(--accent); border-color: var(--accent); }
  .email-hero:hover .arrow { color: var(--accent); transform: translate(4px, -4px); }
  .footer-end {
    margin-top: var(--space-32);
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: var(--space-14);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--muted);
  }
  .socials { display: flex; gap: var(--space-18); }
  .socials a { color: var(--muted); transition: color var(--ease-default); }
  .socials a:hover { color: var(--ink); }

  @media (max-width: 600px) {
    footer { padding: var(--space-56) 0 var(--space-48); }
  }
</style>
