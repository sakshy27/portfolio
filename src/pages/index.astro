---
import Base from '../layouts/Base.astro';
import Topbar from '../components/Topbar.astro';
import Hero from '../components/Hero.astro';
import SectionHead from '../components/SectionHead.astro';
import WorkCard from '../components/WorkCard.astro';
import ExperimentRow from '../components/ExperimentRow.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Topbar />

  <main class="wrap">
    <Hero />

    <!-- Selected work -->
    <section class="sec" id="work">
      <SectionHead title="Selected work" count="04 projects" />
      <div class="work-list">
        <WorkCard
          href="#"
          kicker="P/01 · Work project · Solo designer"
          title="GBOT-X: Gemach Trading Dashboard"
          desc="A trading dashboard designed for speed and clarity, helping traders make faster decisions with real-time data."
          thumbClass="thumb-1"
        />
        <WorkCard
          href="#"
          kicker="P/02 · Eldertech · 2025"
          title="True Companions"
          desc="A digital service platform designed to help elderly individuals stay socially connected, emotionally supported, and confidently engaged with the digital world."
          thumbClass="thumb-2"
        />
        <WorkCard
          href="#"
          kicker="P/03 · B2B · Web app"
          title="Improved transfer status communication"
          desc="Redesigning how users track and understand their transfer statuses, reducing support queries and building trust through transparency."
          thumbClass="thumb-3"
        />
        <WorkCard
          href="#"
          kicker="P/04 · Capstone · 2024"
          title="Dukaan Subscriptions"
          desc="Introducing subscriptions to boost sales and retention for sellers on Dukaan's B2B2C platform."
          thumbClass="thumb-4"
        />
      </div>
    </section>

    <!-- Claude experiments -->
    <section class="sec">
      <SectionHead title="Built with Claude" count="04 experiments" />
      <div class="exp-list">
        <ExperimentRow
          href="#"
          num="EXP/01"
          title="Critique-bot"
          desc="Heuristic feedback for Figma frames, without the usual cruelty."
          stack="Figma plugin"
        />
        <ExperimentRow
          href="#"
          num="EXP/02"
          title="Copy-tone tester"
          desc="Microcopy across five product personalities, side by side."
          stack="React"
        />
        <ExperimentRow
          href="#"
          num="EXP/03"
          title='What "minimal" means'
          desc="Three working prototypes that all claim minimal. Only one is."
          stack="Essay · Demo"
        />
        <ExperimentRow
          href="#"
          num="EXP/04"
          title="Reading-rooms"
          desc="A knowledge tool when allowed to be quiet."
          stack="Prototype"
        />
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .sec { padding: var(--space-48) 0; }
  .work-list { display: flex; flex-direction: column; gap: var(--space-56); }
  .exp-list { display: flex; flex-direction: column; }

  @media (max-width: 600px) {
    .sec { padding: var(--space-32) 0; }
    .work-list { gap: 40px; }
  }
</style>
